<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="WinDialog.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image x:ConnectionId='2' x:Name="IconImage" Grid.Column="0" Width="128" Height="128" Margin="0,0,24,0" VerticalAlignment="Top" Visibility="Collapsed" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            <TextBlock x:ConnectionId='3' x:Name="TitleText" FontSize="24" FontWeight="SemiBold" Text="Title" />
            <ScrollViewer Grid.Row="1" Margin="0,20,0,20">
                <TextBlock x:ConnectionId='7' x:Name="MessageText" TextWrapping="Wrap" Text="Message" FontSize="14" />
            </ScrollViewer>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <TextBlock x:ConnectionId='4' x:Name="TimerText" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" Foreground="Gray" Visibility="Collapsed" />
                <Button x:ConnectionId='5' x:Name="Button1" Content="OK"                          Style="{StaticResource AccentButtonStyle}" />
                <Button x:ConnectionId='6' x:Name="Button2" Content="Cancel" Visibility="Collapsed"                          />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

