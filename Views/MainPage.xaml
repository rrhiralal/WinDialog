<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="WinDialog.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinDialog"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Text="Title" />
            <Border BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Margin="-24,15,-24,0" />
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image x:Name="IconImage" Grid.Column="0" Width="96" Height="96" Margin="0,0,24,0" VerticalAlignment="Top" Visibility="Collapsed" />

            <ScrollViewer Grid.Column="1">
                <controls:MarkdownTextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="15" Background="Transparent" />
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <TextBlock x:Name="TimerText" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" Foreground="Gray" Visibility="Collapsed" />
            <Button x:Name="Button1" Content="OK" Click="OnButton1Clicked" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="Button2" Content="Cancel" Visibility="Collapsed" Click="OnButton2Clicked" />
            <Button x:Name="HelpButton" Click="OnHelpButtonClicked" Visibility="Collapsed" Width="30" Height="30" CornerRadius="15" Padding="0" Margin="10,0,0,0" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}">
                <SymbolIcon Symbol="Help" />
            </Button>
        </StackPanel>
    </Grid>
</Page>
