<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="WinDialog.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" Padding="20" SizeChanged="OnRootGridSizeChanged" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="40" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Text="Title" TextTrimming="CharacterEllipsis" />
            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,12,0,0" />
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image x:Name="IconImage" Grid.Column="0" Width="64" Height="64" Margin="0,0,16,0" VerticalAlignment="Top" Visibility="Collapsed" />

            <WebView2 x:Name="MessageWebView" Grid.Column="1" />
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <TextBlock x:Name="TimerText" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
            <Button x:Name="Button1" Content="OK" Click="OnButton1Clicked" Style="{StaticResource AccentButtonStyle}" MinWidth="80" />
            <Button x:Name="Button2" Content="Cancel" Visibility="Collapsed" Click="OnButton2Clicked" MinWidth="80" />
            <Button x:Name="HelpButton" Click="OnHelpButtonClicked" Visibility="Collapsed" Width="36" Height="36" CornerRadius="18" Padding="0" Margin="8,0,0,0" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}">
                <SymbolIcon Symbol="Help" />
            </Button>
        </StackPanel>
    </Grid>
</Page>
